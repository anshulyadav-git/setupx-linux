# SnappyMail Webmail (HTTPS)
server {
    listen 443 ssl;
    server_name mail.r-u.live;
    ssl_certificate     /etc/letsencrypt/live/r-u.live/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/r-u.live/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:8090;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
        proxy_read_timeout 300;
    }
}

# Portainer Docker UI (HTTPS)
server {
    listen 443 ssl;
    server_name portainer.r-u.live;
    ssl_certificate     /etc/letsencrypt/live/r-u.live/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/r-u.live/privkey.pem;

    location / {
        proxy_pass https://127.0.0.1:9443;
        proxy_http_version 1.1;
        proxy_ssl_verify off;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
        proxy_read_timeout 300;
    }
}
